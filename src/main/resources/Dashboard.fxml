<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane minHeight="500.0" minWidth="950.0" prefHeight="500.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.financemanager.controllers.DashboardController">
   <top>
      <HBox alignment="CENTER" prefHeight="40.0" prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="backToMenuButton" mnemonicParsing="false" onAction="#handleBackToMenu" text="Back to Menu" textAlignment="CENTER">
               <font>
                  <Font size="12.0" />
               </font>
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </Button>
            <Region prefHeight="24.0" prefWidth="134.0" HBox.hgrow="ALWAYS" />
            <HBox prefHeight="100.0" prefWidth="200.0">
               <children>
                  <TextField />
               </children>
            </HBox>
            <Region prefHeight="24.0" prefWidth="304.0" HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Button fx:id="categoriesButton" mnemonicParsing="false" onAction="#handleCategories" text="Categories" textAlignment="CENTER">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="addFileButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#handleAddFile" text="+ Add File" textAlignment="CENTER">
                     <font>
                        <Font size="12.0" />
                     </font>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <TableView fx:id="transactionTable" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="dateColumn" prefWidth="75.0" text="Date" />
          <TableColumn fx:id="typeColumn" prefWidth="75.0" text="Type" />
            <TableColumn fx:id="valueColumn" prefWidth="75.0" text="Value" />
            <TableColumn fx:id="categoryColumn" prefWidth="75.0" text="Category" />
            <TableColumn fx:id="descriptionColumn" prefWidth="249.0" text="Description" />
        </columns>
      </TableView>
   </center>
</BorderPane>
