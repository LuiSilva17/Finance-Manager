<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.financemanager.controllers.CreateManagerController">
   <children>
      <Button fx:id="back_to_menu_button" layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#handleBacktoMenu" text="Back to Menu" textAlignment="CENTER" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="10.0">
         <font>
            <Font size="12.0" />
         </font>
      </Button>
      <Button fx:id="import_file_button" alignment="CENTER" layoutX="50.0" layoutY="250.0" mnemonicParsing="false" onAction="#handleImportManager" prefWidth="300.0" text="Import Manager" textAlignment="CENTER">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Button fx:id="import_file_path_button" layoutX="318.0" layoutY="213.0" mnemonicParsing="false" onAction="#handleImportMenu" text="..." textAlignment="CENTER">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Label fx:id="file_name_label" layoutX="50.0" layoutY="218.0" prefHeight="18.0" prefWidth="32.0">
         <font>
            <Font size="14.0" />
         </font></Label>
   </children>
</AnchorPane>
